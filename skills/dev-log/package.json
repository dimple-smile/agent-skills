{
  "name": "@dimple-smile/dev-log",
  "version": "2.0.0",
  "description": "AI debugging collaboration - collect console.log via HTTP requests",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": "./dist/cli.cjs",
  "scripts": {
    "build": "pkgroll",
    "start": "node dist/cli.cjs",
    "test": "vitest run"
  },
  "keywords": [
    "debugging",
    "frontend",
    "developer-tools",
    "ai",
    "agent-skills"
  ],
  "license": "ISC",
  "dependencies": {
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pkgroll": "^2.15.4",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
